          <mxGeometry x="1090" y="135" width="180" height="40" as="geometry" />
        </mxCell>
        <!-- BR account (center, larger - HUB) -->
        <mxCell id="br-acct" value="Conta BR — Centralizadora + Hub de Observabilidade" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;container=1;pointerEvents=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_account;strokeColor=#CD2264;fillColor=#FFF4F8;verticalAlign=top;align=left;spacingLeft=30;fontColor=#CD2264;strokeWidth=3;" parent="1" vertex="1">
