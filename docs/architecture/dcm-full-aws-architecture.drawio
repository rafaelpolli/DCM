        <!-- Notes -->
        <mxCell id="note-deploy" value="Deploy model: cada conta executa o MESMO Terraform module&#xa;Variáveis: aws_region, vpc_cidr, env, MOCK_MODE (opcional)&#xa;Independência: nenhum acoplamento de execução entre contas&#xa;Mock mode: setar MOCK_MODE=true em qualquer conta serve uma demo&#xa;sem chamadas AWS reais — útil para POCs locais em unidade nova" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#FFF8E1;strokeColor=#FFC107;fontStyle=0;" parent="1" vertex="1">
          <mxGeometry x="40" y="1100" width="600" height="120" as="geometry" />
        </mxCell>
        <mxCell id="note-obs" value="Observabilidade centralizada em BR:&#xa;• Cross-account CloudWatch Observability (sink em BR)&#xa;• Kinesis Firehose envia logs estruturados para BR (logs JSON)&#xa;• Organization CloudTrail concentra audit em S3 central BR&#xa;• Managed Grafana em BR consulta CW e Prometheus cross-account&#xa;• Security Hub agrega findings de todas contas-membro" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#E8F5E9;strokeColor=#7AA116;fontStyle=0;" parent="1" vertex="1">
          <mxGeometry x="660" y="1100" width="680" height="120" as="geometry" />
        </mxCell>
        <mxCell id="note-net" value="Conectividade BR ↔ unidades:&#xa;• VPC Peering ponto-a-ponto (BR ↔ US, BR ↔ EU, BR ↔ ...)&#xa;• CIDRs diferentes por conta (10.0/16 BR, 10.1/16 US, 10.2/16 EU)&#xa;• Sem peering entre unidades (hub-and-spoke implícito)&#xa;• Tráfego entre contas via roteamento privado (não passa pela internet)&#xa;• Acesso AWS service: VPC Endpoints + PrivateLink onde possível" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#F3E5F5;strokeColor=#8C4FFF;fontStyle=0;" parent="1" vertex="1">
          <mxGeometry x="1360" y="1100" width="600" height="120" as="geometry" />
        </mxCell>
